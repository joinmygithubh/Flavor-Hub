# ==========================================================================
# Flavor Hub - Backend Environment Variables
# Copy this file to ".env" and fill in real values. NEVER commit the real .env.
# ==========================================================================

# --- Server ---
PORT=5000
NODE_ENV=development

# Comma-separated list of allowed origins for CORS (no trailing slash).
# Example for local dev with Vite: http://localhost:5173
CLIENT_URL=http://localhost:5173

# --- Database (MongoDB Atlas) ---
# Get this from MongoDB Atlas > Connect > Drivers.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/flavorhub?retryWrites=true&w=majority

# --- Authentication (JWT) ---
# Use a long, random string. Generate with: openssl rand -base64 48
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# --- Payments ---
# This project ships with a built-in MOCK payment gateway (Stripe/Razorpay test-mode
# style) so it runs without external accounts. To wire up a real provider, set these
# and swap the implementation in src/services/paymentService.js.
PAYMENT_PROVIDER=mock
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# RAZORPAY_KEY_ID=rzp_test_xxx
# RAZORPAY_KEY_SECRET=xxx

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX=300

# --- Seed: optional default admin created by the seed script ---
SEED_ADMIN_EMAIL=admin@flavorhub.test
SEED_ADMIN_PASSWORD=Admin@12345
