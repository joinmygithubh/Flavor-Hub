# ==========================================================================
# Flavor Hub - Frontend Environment Variables
# Copy to ".env" and adjust if your API runs somewhere other than localhost:5000.
# Vite only exposes variables prefixed with VITE_.
# ==========================================================================

# Base URL for the backend API. In dev, Vite proxies /api -> localhost:5000,
# so the default relative path works out of the box.
VITE_API_BASE_URL=/api
